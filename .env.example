# ==============================================================================
# FlowPilot AI — Environment Variables
# Copy this file to `.env` and fill in the values you need.
# The app runs out of the box with these defaults (SQLite + Mock AI).
# ==============================================================================

# --- Core ---------------------------------------------------------------------
APP_NAME=FlowPilot AI
ENVIRONMENT=development
# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Security -----------------------------------------------------------------
# Generate a strong secret in production, e.g. `openssl rand -hex 32`
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database -----------------------------------------------------------------
# Default is SQLite for zero-setup local dev.
# For PostgreSQL (via docker-compose) use:
# DATABASE_URL=postgresql+psycopg://flowpilot:flowpilot@localhost:5432/flowpilot
DATABASE_URL=sqlite:///./flowpilot.db

# --- Redis / Background jobs --------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# inline = run executions synchronously in the request (no worker needed, great for demos)
# celery = enqueue executions to a Celery worker (requires Redis + worker running)
EXECUTION_MODE=inline

# --- AI Provider --------------------------------------------------------------
# AI_PROVIDER: openrouter | mock
# Falls back to the deterministic mock automatically if no key is set.
AI_PROVIDER=mock

# Get a key at https://openrouter.ai/keys — one key reaches many models.
OPENROUTER_API_KEY=

# AI_MODEL is optional (default: openrouter/free — auto-picks a free model, $0).
# Override for more consistent quality (vendor/model form):
#   openrouter/free                 (free auto-router; default)
#   openai/gpt-4o-mini              (cheap, reliable)
#   anthropic/claude-3.5-sonnet     (highest quality)
# Browse models at https://openrouter.ai/models
AI_MODEL=
