# ==============================================================================
# FlowPilot AI — Environment Variables
# Copy this file to `.env` and fill in the values you need.
# The app runs out of the box with these defaults (SQLite + Mock AI).
# ==============================================================================

# --- Core ---------------------------------------------------------------------
APP_NAME=FlowPilot AI
ENVIRONMENT=development
# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Security -----------------------------------------------------------------
# Generate a strong secret in production, e.g. `openssl rand -hex 32`
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database -----------------------------------------------------------------
# Default is SQLite for zero-setup local dev.
# For PostgreSQL (via docker-compose) use:
# DATABASE_URL=postgresql+psycopg://flowpilot:flowpilot@localhost:5432/flowpilot
DATABASE_URL=sqlite:///./flowpilot.db

# --- Redis / Background jobs --------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# inline = run executions synchronously in the request (no worker needed, great for demos)
# celery = enqueue executions to a Celery worker (requires Redis + worker running)
EXECUTION_MODE=inline

# --- AI Provider --------------------------------------------------------------
# AI_PROVIDER: openai | anthropic | openrouter | mock
# Auto-falls back to the deterministic mock if the chosen provider has no key.
AI_PROVIDER=mock

# AI_MODEL is optional; each provider has a sensible cheap default.
#   openai      -> gpt-4o-mini
#   anthropic   -> claude-haiku-4-5-20251001
#   openrouter  -> openai/gpt-4o-mini   (use vendor/model form, e.g.
#                  anthropic/claude-3.5-sonnet, meta-llama/llama-3.1-8b-instruct:free)
AI_MODEL=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Get one key at https://openrouter.ai/keys to reach many models (some free).
OPENROUTER_API_KEY=
